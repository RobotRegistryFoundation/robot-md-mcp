{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robotmd.dev/schema/v1/robot.schema.json",
  "title": "ROBOT.md frontmatter — v1",
  "description": "JSON Schema for the YAML frontmatter block of a ROBOT.md file.",
  "type": "object",
  "required": ["rcan_version", "metadata", "physics", "drivers", "safety"],
  "properties": {
    "rcan_version": {
      "type": "string",
      "pattern": "^3\\.[0-9]+(\\.[0-9]+)?$",
      "description": "RCAN protocol version. Must be 3.0 or higher (ecosystem policy: RCAN 3.0+ only going forward; 2.x no longer accepted)."
    },
    "schema": {
      "type": "string",
      "format": "uri",
      "description": "Optional self-reference to the JSON schema this file conforms to."
    },
    "metadata": {
      "type": "object",
      "required": ["robot_name"],
      "properties": {
        "robot_name": { "type": "string", "minLength": 1, "maxLength": 64 },
        "rrn": { "type": "string", "pattern": "^(RRN-[0-9]{12}|)$" },
        "rrn_uri": { "type": "string", "pattern": "^rrn://.+" },
        "ruri": { "type": "string", "pattern": "^rcan://.+" },
        "rcn_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^RCN-[0-9]{12}$" },
          "uniqueItems": true,
          "description": "Robot Component Numbers identifying this robot's constituent components (sensors, actuators, SBC, etc.) as registered on RRF /v2/components. Ships v0.9.6 alongside RMN/RHN for the v1.0.0 compliance declaration."
        },
        "rmn": {
          "type": "string",
          "pattern": "^RMN-[0-9]{12}$",
          "description": "Robot Model Number — RRF-registered identity of the underlying platform model (e.g. the reference SKU from which this instance was built)."
        },
        "rhn_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^RHN-[0-9]{12}$" },
          "uniqueItems": true,
          "description": "Robot Harness Numbers identifying tested harness/cabling configurations this robot conforms to, as registered on RRF /v2/harnesses."
        },
        "manufacturer": { "type": "string" },
        "model": { "type": "string" },
        "version": { "type": "string" },
        "license": { "type": "string" }
      },
      "additionalProperties": true
    },
    "physics": {
      "type": "object",
      "required": ["type", "dof"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["arm", "wheeled", "tracked", "legged", "arm+camera", "humanoid", "sensor", "other"]
        },
        "dof": { "type": "integer", "minimum": 0, "maximum": 64 },
        "kinematics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "axis": { "type": "string", "enum": ["x", "y", "z"] },
              "limits_deg": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              },
              "limits_mm": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              },
              "length_mm": {
                "type": "number",
                "minimum": 0,
                "description": "Legacy scalar — fallback for `a_mm` when DH params aren't declared. Treated as the horizontal offset from this joint to the next."
              },
              "a_mm": {
                "type": "number",
                "description": "DH parameter: distance from this joint's axis to the next joint's axis along the local +x direction (perpendicular to this joint's rotation axis)."
              },
              "d_mm": {
                "type": "number",
                "description": "DH parameter: distance from this joint's axis to the next joint's axis along this joint's rotation axis. For a vertical shoulder_pan riser, d_mm is the vertical height to the shoulder_lift joint."
              },
              "servo_id": {
                "type": "integer",
                "minimum": 0,
                "description": "Bus address of the servo driving this joint. Maps joint to the corresponding driver entry. Set by `robot-md autodetect` from the driver config."
              },
              "encoder_sign": {
                "type": "integer",
                "enum": [-1, 1],
                "description": "+1 if positive encoder delta ⇒ positive joint-angle delta; -1 if the encoder is reversed relative to the kinematic convention. Populated by `robot-md calibrate --sign` after observing one test move per joint."
              },
              "zero_pose_steps": {
                "type": "integer",
                "minimum": 0,
                "description": "Encoder reading when this joint is at 0° in the kinematic convention. Recorded by `robot-md calibrate --zero` while the operator holds the arm in its declared zero pose."
              }
            },
            "additionalProperties": true
          }
        },
        "poses": {
          "type": "object",
          "description": "Named joint-space poses. 'ready' is the manipulation home if present.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "joints": { "type": "object", "additionalProperties": { "type": "integer" } },
              "source": { "type": "string", "enum": ["declared", "taught", "solved_from_dh"] },
              "taught_at": { "type": "string" }
            },
            "required": ["joints"]
          }
        },
        "workspace": {
          "type": "object",
          "description": "Reachable envelope, relative to a named pose.",
          "properties": {
            "from_pose": {"type": "string"},
            "bounds_mm": {
              "type": "object",
              "properties": {
                "x": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
                "y": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
                "z": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2}
              }
            },
            "note": {"type": "string"}
          }
        },
        "solver": {
          "type": "object",
          "description": "Baseline IK metadata — enough for a planner to compute forward/inverse kinematics from ROBOT.md alone, without an external URDF. Populated by `robot-md autodetect` (deterministic fields) + `robot-md calibrate` (physical fields).",
          "properties": {
            "convention": {
              "type": "string",
              "enum": ["DH", "URDF", "custom"],
              "description": "Kinematic convention used by the `kinematics[]` array. `DH` = modified Denavit-Hartenberg (axis + length_mm per joint). `URDF` = reference an external URDF file via `extensions.urdf_ref`. `custom` = body prose must describe the convention."
            },
            "base_frame": {
              "type": "object",
              "description": "World-frame convention for the arm base.",
              "properties": {
                "up": { "type": "string", "enum": ["x", "y", "z"] },
                "forward": { "type": "string", "enum": ["x", "y", "z"] }
              }
            },
            "encoder": {
              "type": "object",
              "description": "Encoder-to-angle conversion. Per-joint overrides live in `kinematics[].encoder_sign` / `.zero_pose_steps`.",
              "properties": {
                "steps_per_rev": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Encoder steps per full revolution (360°). Default for the arm. Autodetect fills this from driver type (Feetech STS3215 = 4096, Dynamixel XM430 = 4096, etc)."
                }
              }
            },
            "camera": {
              "type": "object",
              "description": "Camera mount relationship to the kinematic chain — needed to project image pixels into the arm's frame.",
              "properties": {
                "mount": {
                  "type": "string",
                  "description": "Where the camera is mounted. `world` = fixed frame (eye-to-hand). `tool0` = end-effector (eye-in-hand). `link_<id>` = a specific intermediate link."
                },
                "extrinsic": {
                  "type": ["array", "null"],
                  "description": "6-DoF transform from the mount frame to the camera frame: [tx, ty, tz, rx, ry, rz] in mm and radians. Null if calibration is required at runtime.",
                  "items": { "type": "number" },
                  "minItems": 6,
                  "maxItems": 6
                }
              }
            },
            "gripper": {
              "type": "object",
              "description": "Gripper geometry + actuation calibration. Needed so a planner can compute where the tip lands given a wrist pose.",
              "properties": {
                "joint_id": {
                  "type": "string",
                  "description": "Which entry in `kinematics[]` is the gripper (end-effector)."
                },
                "tip_offset_mm": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3,
                  "description": "[x, y, z] offset from the gripper's link frame to the grasp point, in mm."
                },
                "open_steps": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Encoder target for the gripper-open pose."
                },
                "close_steps": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Encoder target for the gripper-close pose."
                }
              }
            },
            "cameras": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["driver_id", "primary_stream", "mount"],
                "properties": {
                  "driver_id": { "type": "string" },
                  "primary_stream": {
                    "type": "string",
                    "enum": ["rgb", "left", "right", "depth", "mono", "ir", "thermal"]
                  },
                  "mount": {
                    "type": "string",
                    "pattern": "^(world|tool0|link_[a-z0-9_]+)$"
                  },
                  "extrinsic": {
                    "type": ["array", "null"],
                    "items": { "type": "number" },
                    "minItems": 6,
                    "maxItems": 6
                  },
                  "extrinsic_source": {
                    "type": ["string", "null"],
                    "enum": ["preset_default", "hand_eye_calibrated", "gripper_silhouette_calibrated", "user_declared", null],
                    "description": "Provenance of extrinsic. `preset_default`: shipped guess. `hand_eye_calibrated`: legacy hand-eye. `gripper_silhouette_calibrated`: from `robot-md calibrate --extrinsic`. `user_declared`: edited by hand."
                  },
                  "extrinsic_residual_mm": {
                    "type": "number",
                    "description": "Mean residual (mm) from the last calibration; written by calibrate --extrinsic."
                  }
                },
                "additionalProperties": false
              }
            },
            "ik_provider": {"type": ["string", "null"]},
            "ik_frame":    {"type": ["string", "null"]}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "vision": {
      "type": "object",
      "description": "Perception vocabulary — objects the robot knows how to see.",
      "properties": {
        "object_descriptors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "detector", "params"],
            "properties": {
              "id":       {"type": "string"},
              "detector": {"type": "string", "enum": ["hsv", "hsv_roi"]},
              "params":   {"type": "object"}
            }
          }
        }
      }
    },
    "drivers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "protocol"],
        "properties": {
          "id": { "type": "string" },
          "protocol": { "type": "string" },
          "port": { "type": "string" },
          "baud_rate": { "type": "integer" },
          "model": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 },
          "backend": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Optional entry-point name forcing a specific CapabilityBackend for this driver."
          },
          "streams": {
            "type": "object",
            "propertyNames": { "pattern": "^(rgb|left|right|depth|mono|ir|thermal)$" },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "intrinsic": {
                  "oneOf": [
                    { "type": "null" },
                    {
                      "type": "object",
                      "required": ["fx", "fy", "cx", "cy", "width", "height"],
                      "properties": {
                        "fx": { "type": "number", "exclusiveMinimum": 0 },
                        "fy": { "type": "number", "exclusiveMinimum": 0 },
                        "cx": { "type": "number" },
                        "cy": { "type": "number" },
                        "width": { "type": "integer", "minimum": 1 },
                        "height": { "type": "integer", "minimum": 1 },
                        "distortion_model": {
                          "type": "string",
                          "enum": ["plumb_bob", "equidistant", "rational", "none"]
                        },
                        "distortion_coeffs": {
                          "type": "array",
                          "items": { "type": "number" }
                        }
                      },
                      "allOf": [
                        {
                          "if": { "properties": { "distortion_model": { "const": "plumb_bob" } }, "required": ["distortion_model"] },
                          "then": { "properties": { "distortion_coeffs": { "minItems": 5, "maxItems": 5 } }, "required": ["distortion_coeffs"] }
                        },
                        {
                          "if": { "properties": { "distortion_model": { "const": "equidistant" } }, "required": ["distortion_model"] },
                          "then": { "properties": { "distortion_coeffs": { "minItems": 4, "maxItems": 4 } }, "required": ["distortion_coeffs"] }
                        },
                        {
                          "if": { "properties": { "distortion_model": { "const": "rational" } }, "required": ["distortion_model"] },
                          "then": { "properties": { "distortion_coeffs": { "minItems": 8, "maxItems": 8 } }, "required": ["distortion_coeffs"] }
                        }
                      ],
                      "additionalProperties": false
                    }
                  ]
                },
                "baseline_m": { "type": "number" },
                "derived_from": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["rgb", "left", "right", "depth", "mono", "ir", "thermal"] },
                  "minItems": 1
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": true
      }
    },
    "safety": {
      "type": "object",
      "required": ["estop"],
      "properties": {
        "p66_enabled": { "type": "boolean" },
        "loa_enforcement": { "type": "boolean" },
        "max_joint_velocity_dps": {
          "type": "number",
          "minimum": 0,
          "maximum": 36000,
          "description": "Sanity bound: 36000 dps = 100 RPS. Physically absurd values above this are rejected at validation time so a malformed or hostile manifest can't declare 'unlimited' and slip past the planner."
        },
        "max_linear_velocity_ms": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Sanity bound: 100 m/s = 360 km/h. Anything faster is not a robot."
        },
        "payload_kg": {
          "type": "number",
          "minimum": 0,
          "maximum": 10000,
          "description": "Sanity bound: 10000 kg. Anything heavier is industrial/construction class — use a vertical-specific spec rather than ROBOT.md v1."
        },
        "workspace_bounds_m": {
          "type": "array",
          "items": { "type": "number", "minimum": 0, "maximum": 1000 },
          "minItems": 3,
          "maxItems": 3,
          "description": "Optional [x, y, z] workspace envelope in meters. Planner must not command beyond these bounds."
        },
        "failsafe_behavior": {
          "type": "string",
          "enum": ["stop", "hold", "home", "custom"],
          "description": "What the robot does when control comms are lost. 'stop' is safest for most physical systems; 'hold' preserves position for stateful tasks; 'home' returns to a declared safe pose; 'custom' requires explicit prose in the body."
        },
        "estop": {
          "type": "object",
          "required": ["software", "response_ms"],
          "properties": {
            "hardware": { "type": "boolean" },
            "software": { "type": "boolean", "const": true },
            "response_ms": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5000,
              "description": "Bound tightened to 5000 ms (was 10000). A responsible robot E-stop should complete in well under 1 second; 5s is the outer envelope, anything higher is suspect."
            }
          },
          "additionalProperties": true
        },
        "hitl_gates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scope"],
            "properties": {
              "scope": { "type": "string" },
              "require_auth": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*\\.[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)?$"
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "rrf_endpoint": { "type": "string", "format": "uri" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "signing_alg": {
          "type": "string",
          "enum": ["ed25519", "ml-dsa-65", "pqc-hybrid-v1"]
        },
        "transports": {
          "type": "array",
          "items": { "type": "string", "enum": ["http", "https", "mqtt", "ws", "wss", "coap"] }
        }
      },
      "additionalProperties": true
    },
    "brain": {
      "type": "object",
      "properties": {
        "planning": {
          "type": "object",
          "properties": {
            "provider": { "type": "string" },
            "model": { "type": "string" },
            "confidence_gate": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": true
        },
        "reactive": {
          "type": "object",
          "properties": {
            "provider": { "type": "string" },
            "model": { "type": "string" }
          },
          "additionalProperties": true
        },
        "task_routing": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "compliance": {
      "type": "object",
      "properties": {
        "fria_ref": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "annex_iii_basis": {
          "type": "string",
          "enum": [
            "safety_component",
            "biometric",
            "critical_infrastructure",
            "education",
            "employment",
            "essential_services",
            "law_enforcement",
            "migration",
            "administration_of_justice",
            "general_purpose_ai"
          ],
          "description": "EU AI Act Annex III use-case basis per rcan-spec §22. When set, compliance.fria_ref MUST be a non-null URI (FRIA gate, enforced since v0.9.2)."
        },
        "iso_42001": {
          "type": "object",
          "properties": {
            "self_assessed": { "type": "boolean" },
            "level": { "type": "integer", "minimum": 1, "maximum": 5 }
          },
          "additionalProperties": true
        },
        "eu_ai_act": {
          "type": "object",
          "properties": {
            "audit_retention_days": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "description": "v0.9.2 FRIA gate per rcan-spec §22: declaring annex_iii_basis commits the operator to a Fundamental Rights Impact Assessment, so fria_ref must be present and a non-null absolute URI. Pattern enforces an RFC 3986 scheme + colon + non-empty path/authority — portable across jsonschema installs that do or don't have rfc3987 format extras.",
          "if": { "required": ["annex_iii_basis"] },
          "then": {
            "required": ["fria_ref"],
            "properties": {
              "fria_ref": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*:.+"
              }
            }
          }
        }
      ],
      "additionalProperties": true
    },
    "federation": {
      "type": "object",
      "properties": {
        "peer_rrns": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(RRN-[0-9]{12}|rrn://.+)$" }
        }
      },
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "patternProperties": {
        "^x-[a-z0-9_-]+$": { "type": "object" }
      },
      "additionalProperties": false
    },
    "capability_contracts": {
      "type": "object",
      "description": "Per-capability preconditions and arg/return contracts.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "preconditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "pose_taught",
                    "extrinsic_present",
                    "ik_provider_set",
                    "workspace_declared",
                    "learned_skill_ok",
                    "backend_resolved"
                  ]
                },
                "name": { "type": "string" },
                "detail": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "learned_skills": {
      "type": "array",
      "description": "Append-only skill catalogue — what the robot has empirically demonstrated.",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id":          {"type": "string"},
          "status":      {"type": "string", "enum": ["ok", "blocked", "degraded"]},
          "validated":   {"type": "array",  "items": {"type": "string"}},
          "blocked_by":  {"type": "array",  "items": {"type": "string"}},
          "notes":       {"type": "string"},
          "recorded_at": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": true
}
